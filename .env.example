# JWT Settings
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# Database Settings
DATABASE_URL=postgresql://username:password@localhost:5432/jonda_db

# GCS Settings
GCS_BUCKET_NAME=your-gcs-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcs-key.json

# API Key Settings (comma-separated key:app_name pairs - fallback for testing only)
# Note: In production, API keys are validated against the database
API_KEYS=test-key-1:app1,test-key-2:app2
